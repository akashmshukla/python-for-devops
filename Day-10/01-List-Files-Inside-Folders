import os

folders=input("Please provide the list of folder names separated by space: ").split()

for folder in folders:
    print("--------- Listing files for the folder " + folder + " ---------")
    try:
        files = os.listdir(folder)
    except FileNotFoundError:
        print("Please provide a valid folder name")
        continue     #This is important to give else code will throw error files not defined
    except PermissionError:
        print("You don't have access to the folder "+ folder)
        continue
    for file in files:
        print(file)